<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>hizliyim.com - HizliyimSystem</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React ve ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <!-- Babel -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">

    <style>
        :root {
            --brand-blue: #027AFF;
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            width: 100vw;
            min-height: 100vh;
            overflow-x: hidden; 
            overflow-y: auto;
            color: white;
            transition: background 1s ease;
        }

        /* --- TEMA ARKAPLANLARI (SADECE GECE MODU AKTİF BALIM) --- */
        body.night-mode {
            background: black;
        }
        
        body.night-mode .bg-gradient-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(180deg, #000000 0%, #05051a 50%, #000814 100%);
            z-index: -5;
            display: block;
        }

        /* --- EFEKT KONTEYNERLARI --- */
        #static-stars-container, #night-effects-container {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            display: none;
        }
        
        #static-stars-container { z-index: -4; }
        #night-effects-container { z-index: -3; }

        .static-star {
            position: absolute;
            background: white;
            border-radius: 50%;
            opacity: 0.6;
            animation: twinkle infinite ease-in-out;
        }
        @keyframes twinkle {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.9; }
        }

        .shooting-star {
            position: absolute;
            width: 100px; height: 1px;
            background: linear-gradient(90deg, transparent, white, transparent);
            transform: rotate(-45deg);
            opacity: 0;
            animation: shoot linear forwards;
        }
        @keyframes shoot {
            0% { transform: translate(0,0) rotate(-45deg); opacity: 1; }
            100% { transform: translate(-400px, 400px) rotate(-45deg); opacity: 0; }
        }

        .speed-line {
            position: absolute;
            width: 30%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            animation: speedMove linear forwards;
        }
        @keyframes speedMove {
            0% { transform: translateX(0); opacity: 0; }
            50% { opacity: 0.5; }
            100% { transform: translateX(100vw); opacity: 0; }
        }

        /* --- LOGO STİLİ (ALİCİMMMM BALIMMM İÇİN ÖZEL) --- */
        .hlogo-last-style {
            filter: invert(1) drop-shadow(0 0 10px rgba(0, 243, 255, 0.7));
            animation: logoBreath 4s infinite ease-in-out;
            max-width: 100px;
            margin-bottom: 1.5rem;
            height: auto;
        }
        @keyframes logoBreath {
            0%, 100% { opacity: 0.8; transform: scale(1); filter: invert(1) drop-shadow(0 0 5px rgba(255, 255, 255, 0.4)); }
            50% { opacity: 1; transform: scale(1.05); filter: invert(1) drop-shadow(0 0 18px rgba(0, 243, 255, 0.9)); }
        }

        /* --- MENÜ KARTI (ORTAK STİL) --- */
        .glass-panel {
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 24px;
            padding: 1.5rem;
            width: 100%;
            display: flex;
            flex-direction: column;
            position: relative;
            z-index: 50;
            transition: all 0.5s ease;
            overflow: hidden;
        }

        body.night-mode .glass-panel {
            background: linear-gradient(135deg, rgba(0, 60, 180, 0.65), rgba(0, 30, 120, 0.65));
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-top: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        }

        /* --- BAŞLIK ANİMASYONLARI BALIM --- */
        .animated-title {
            font-family: 'Inter', sans-serif;
            font-weight: 900;
            letter-spacing: -1px;
            text-align: center;
        }

        /* Giriş ekranındaki şatafatlı efekt balımmmm */
        .login-title-effect {
            background: linear-gradient(to right, #ffffff 0%, #00f3ff 50%, #ffffff 100%);
            background-size: 200% auto;
            color: #fff;
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shineMove 3s linear infinite;
        }

        /* Ana menüdeki eski asil gece parlaması balımmmm */
        .dashboard-title-effect {
            color: #fff;
            animation: intensePulse 3s infinite ease-in-out;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
        }

        @keyframes shineMove {
            0% { background-position: 200% center; }
            100% { background-position: -200% center; }
        }

        @keyframes intensePulse {
            0%, 100% { text-shadow: 0 0 10px rgba(255, 255, 255, 0.5); }
            50% { text-shadow: 0 0 25px rgba(2, 122, 255, 0.8), 0 0 50px rgba(2, 122, 255, 0.4); }
        }

        /* Inputlar */
        .custom-input {
            width: 100%;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: white;
            padding: 14px 20px;
            border-radius: 16px;
            outline: none;
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }
        .custom-input:focus {
            background: rgba(255, 255, 255, 0.2);
            border-color: #4da3ff;
            box-shadow: 0 0 15px rgba(2, 122, 255, 0.2);
        }

        /* Butonlar */
        .action-btn {
            width: 100%; font-weight: 800; padding: 16px;
            border-radius: 16px; border: none; cursor: pointer;
            transition: transform 0.2s ease, background 0.2s ease;
            font-size: 1rem; text-transform: uppercase; letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2); margin-top: 10px;
            background: #ffffff; color: #027AFF;
        }
        .action-btn:hover { transform: translateY(-2px); filter: brightness(1.1); }

        .animate-pop-in { animation: popIn 0.5s ease-out forwards; }
        @keyframes popIn {
            from { opacity: 0; transform: scale(0.98); }
            to { opacity: 1; transform: scale(1); }
        }

        /* --- GİRİŞ EKRANI İÇİN YUKARIDAN SÜZÜLME EFEKTİ BALIM --- */
        .animate-slide-down {
            animation: slideDownFade 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes slideDownFade {
            0% { opacity: 0; transform: translateY(-100px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        /* --- GEÇİŞ (SLIDE) EFEKTLERİ BALIM --- */
        .slide-out-left {
            animation: slideOutLeft 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes slideOutLeft {
            0% { transform: translateX(0); opacity: 1; }
            100% { transform: translateX(-150px); opacity: 0; }
        }

        .slide-in-right {
            animation: slideInRight 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes slideInRight {
            0% { transform: translateX(150px); opacity: 0; }
            100% { transform: translateX(0); opacity: 1; }
        }

        /* --- YENİ PASSCODE YILDIZ (STAR) EFEKTİ BALIM --- */
        @keyframes starPop {
            0% { transform: scale(0); opacity: 0; }
            50% { transform: scale(1.4); opacity: 1; box-shadow: 0 0 15px #00f3ff; }
            100% { transform: scale(1); opacity: 1; box-shadow: 0 0 8px #fff; }
        }
        .animate-star-pop {
            animation: starPop 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* --- SAYILAR İÇİN SABİT GLOW EFEKTLERİ BALIM --- */
        .static-glow {
            text-shadow: 0 0 15px rgba(255, 255, 255, 0.5);
            display: inline-block;
        }

        .static-overload-glow {
            text-shadow: 0 0 20px rgba(239, 68, 68, 0.8);
            display: inline-block;
            animation: overloadPulse 2s infinite alternate;
        }
        @keyframes overloadPulse {
            0% { text-shadow: 0 0 10px rgba(239, 68, 68, 0.5); }
            100% { text-shadow: 0 0 35px rgba(239, 68, 68, 1); }
        }

        .overload-panel {
            border-color: rgba(239, 68, 68, 0.8) !important;
            box-shadow: 0 0 50px rgba(239, 68, 68, 0.4) !important;
            animation: panelPulse 2s infinite;
        }
        @keyframes panelPulse {
            0%, 100% { box-shadow: 0 0 30px rgba(239, 68, 68, 0.3); }
            50% { box-shadow: 0 0 60px rgba(239, 68, 68, 0.6); border-color: rgba(239, 68, 68, 1); }
        }

        /* --- SİSTEM AKTİF (SCANNING) BARI KUTUNUN İÇİNDE KALIR --- */
        .scan-bar-container {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 4px;
            background: transparent;
            overflow: hidden;
            z-index: 100;
        }
        .scan-bar-indicator {
            position: absolute;
            top: 0; left: 0; height: 100%; width: 25%;
            border-radius: 4px;
            animation: scanMove 2s ease-in-out infinite alternate;
            will-change: transform;
        }
        @keyframes scanMove {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(400%); }
        }

        /* --- SLIDE TO UNLOCK / ALTERNATİF GİRİŞ EFEKTLERİ BALIM --- */
        .slide-text-gradient {
            background: linear-gradient(to right, rgba(255,255,255,0.3) 0%, rgba(255,255,255,1) 50%, rgba(255,255,255,0.3) 100%);
            background-size: 200% auto;
            color: #fff;
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shineMove 3s linear infinite;
        }

        .swipe-hidden-input {
            position: absolute !important;
            top: 0 !important; left: 0 !important;
            width: 100% !important; height: 100% !important;
            opacity: 0 !important;
            cursor: pointer !important;
            z-index: 20 !important;
        }
        .swipe-hidden-input::-webkit-slider-thumb {
            -webkit-appearance: none !important;
            width: 80px !important;
            height: 80px !important;
            margin-top: 0 !important;
        }
        .swipe-hidden-input::-webkit-slider-runnable-track {
            height: 100% !important;
            background: transparent !important;
        }

        /* Slider Custom */
        input[type=range] { -webkit-appearance: none; background: transparent; }
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none; height: 20px; width: 20px;
            border-radius: 50%; background: #ffffff;
            cursor: pointer; margin-top: -8px; box-shadow: 0 0 10px rgba(255,255,255,0.5);
        }
        input[type=range]::-webkit-slider-runnable-track {
            width: 100%; height: 4px; cursor: pointer;
            background: rgba(255,255,255,0.2); border-radius: 2px;
        }
    </style>
</head>
<body id="body-main" class="night-mode">

    <!-- Efekt Konteynerları (Sadece Gece Efektleri Var Balım) -->
    <div class="bg-gradient-overlay"></div>
    <div id="static-stars-container"></div>
    <div id="night-effects-container"></div>

    <!-- ROOT CONTAINER - KAYDIRMA DESTEKLİ -->
    <div class="min-h-screen w-full flex flex-col justify-center items-center py-12 px-4">
        <div id="root" class="w-full max-w-[480px]"></div>
    </div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        // EFEKT FONKSİYONLARI (SADECE GECE MODU BALIM)
        let shootingStarInterval, speedLineInterval;

        function initNightEffects() {
            const nightContainer = document.getElementById('night-effects-container');
            const staticContainer = document.getElementById('static-stars-container');
            nightContainer.innerHTML = ''; staticContainer.innerHTML = ''; 
            nightContainer.style.display = 'block'; staticContainer.style.display = 'block';

            shootingStarInterval = setInterval(() => createStar(nightContainer, 'shooting-star'), 2500); 
            speedLineInterval = setInterval(() => createStar(nightContainer, 'speed-line'), 800);

            const starCount = 60;
            for (let i = 0; i < starCount; i++) {
                const star = document.createElement('div');
                star.classList.add('static-star');
                star.style.left = `${Math.random() * 100}%`;
                star.style.top = `${Math.random() * 100}%`;
                const size = Math.random() * 2 + 1; 
                star.style.width = `${size}px`; star.style.height = `${size}px`;
                star.style.animationDuration = `${Math.random() * 3 + 2}s`; 
                staticContainer.appendChild(star);
            }
        }

        function createStar(container, type) {
            if (container.children.length > 20) return; 
            const el = document.createElement('div');
            el.classList.add(type);
            if (type === 'shooting-star') {
                el.style.top = Math.random() * 50 + '%';
                el.style.left = Math.random() * 100 + '%';
                el.style.animationDuration = '2s';
            } else {
                el.style.top = Math.random() * 100 + 'vh';
                el.style.height = '1px';
                el.style.animationDuration = '0.5s';
                el.style.left = Math.random() > 0.5 ? '-10%' : 'auto';
                if(el.style.left === 'auto') el.style.right = '-10%';
            }
            container.appendChild(el);
            setTimeout(() => el.remove(), 2100);
        }

        function clearNightEffects() {
            clearInterval(shootingStarInterval);
            clearInterval(speedLineInterval);
        }

        // --- YENİ EKLENEN "SAYAN RAKAM" BİLEŞENİ BALIM ---
        const AnimatedNumber = ({ value, decimals = 0 }) => {
            const [displayValue, setDisplayValue] = useState(value);
            
            useEffect(() => {
                let start = displayValue;
                let end = value;
                if (start === end) return;
                
                const duration = 1200; 
                const startTime = performance.now();
                
                const animate = (currentTime) => {
                    const elapsed = currentTime - startTime;
                    const progress = Math.min(elapsed / duration, 1);
                    const ease = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
                    
                    const current = start + (end - start) * ease;
                    setDisplayValue(current);
                    
                    if (progress < 1) requestAnimationFrame(animate);
                    else setDisplayValue(end);
                };
                
                requestAnimationFrame(animate);
            }, [value]);

            const formatOptions = { minimumFractionDigits: decimals, maximumFractionDigits: decimals };
            return <>{Number(displayValue).toLocaleString('tr-TR', formatOptions)}</>;
        };

        // --- ANA UYGULAMA ---
        const App = () => {
            const [view, setView] = useState('login');
            const [user, setUser] = useState({ email: '', pass: '' });
            const [loading, setLoading] = useState(false);
            const [loginError, setLoginError] = useState(''); 
            
            // Alternatif Giriş (Kaydırma) States Balım
            const [sliderValue, setSliderValue] = useState(0);
            const [altLoginState, setAltLoginState] = useState('idle'); 
            const [passcode, setPasscode] = useState(''); 
            const passcodeRef = useRef(null); 

            // TARAYICI HAFIZASINDAN DEĞERLERİ ÇEKİYORUZ BALIM (LOCALSTORAGE)
            const savedUsers = Number(localStorage.getItem('hizliyim_users')) || 8400;
            const savedCpu = Number(localStorage.getItem('hizliyim_cpu')) || 40;
            const savedRam = Number(localStorage.getItem('hizliyim_ram')) || 37;
            const savedAnnouncement = localStorage.getItem('hizliyim_announcement') || "Sistem v4.9 güncellendi. Hafıza (Memory) modülü aktif edildi.";

            // Admin Panel States (Hafızadan başlıyorlar)
            const [activeUsers, setActiveUsers] = useState(savedUsers);
            const [baseCount, setBaseCount] = useState(savedUsers);
            const [cpu, setCpu] = useState(savedCpu);
            const [ram, setRam] = useState(savedRam);
            const [baseCpu, setBaseCpu] = useState(savedCpu); 
            const [baseRam, setBaseRam] = useState(savedRam); 
            
            const [announcement, setAnnouncement] = useState(savedAnnouncement);
            const [showAccountMenu, setShowAccountMenu] = useState(false);
            const [showSettings, setShowSettings] = useState(false);
            const [isExiting, setIsExiting] = useState(false);

            // HAFIZAYA KAYDETME İŞLEMİ (Her değiştiğinde otomatik kaydeder balım)
            useEffect(() => {
                localStorage.setItem('hizliyim_users', baseCount);
                localStorage.setItem('hizliyim_cpu', baseCpu);
                localStorage.setItem('hizliyim_ram', baseRam);
                localStorage.setItem('hizliyim_announcement', announcement);
            }, [baseCount, baseCpu, baseRam, announcement]);

            // Tema ve Efekt Kontrolü
            useEffect(() => {
                initNightEffects();
                return () => clearNightEffects(); 
            }, []);

            // Trafik Döngüsü (Maksimum sınır 40k yapıldı balım)
            useEffect(() => {
                const interval = setInterval(() => {
                    const noise = Math.floor(Math.random() * 100) - 50;
                    setActiveUsers(prev => {
                        let val = baseCount + noise;
                        if(val > 40000) val = 40000; // 40K LİMİTİ BURADA BALIM
                        if(val < 0) val = 0;
                        return val;
                    });
                    
                    setCpu(Math.max(5, Math.min(99, baseCpu + (Math.random() * 2 - 1))));
                    setRam(Math.max(10, Math.min(99, baseRam + (Math.random() * 2 - 1))));
                }, 2500);
                return () => clearInterval(interval);
            }, [baseCount, baseCpu, baseRam]);

            const handleLogin = (e) => {
                e.preventDefault();
                setLoading(true);
                setLoginError(''); 
                
                setTimeout(() => {
                    if (user.email === 'root' && user.pass === 'iremim') {
                        setLoading(false);
                        setIsExiting(true); 
                        setTimeout(() => {
                            setView('dashboard');
                            setIsExiting(false);
                        }, 600); 
                    } else {
                        setLoginError('Hatalı ID veya password!');
                        setLoading(false);
                    }
                }, 800);
            };

            const handlePasscodeChange = (e) => {
                const val = e.target.value.replace(/[^0-9]/g, ''); 
                if (val.length <= 4) {
                    setPasscode(val);
                }
                if (val.length === 4) {
                    if (passcodeRef.current) passcodeRef.current.blur();
                }
            };

            const handleSliderChange = (e) => {
                if (altLoginState !== 'idle') return;
                const val = Number(e.target.value);
                setSliderValue(val);
                
                if (val >= 99) {
                    setAltLoginState('loading');
                    setSliderValue(100);
                    
                    setTimeout(() => {
                        if (passcode === '0000') {
                            setAltLoginState('success');
                            
                            setTimeout(() => {
                                setIsExiting(true);
                                setTimeout(() => {
                                    setView('dashboard');
                                    setIsExiting(false);
                                    
                                    setTimeout(() => {
                                        setAltLoginState('idle');
                                        setSliderValue(0);
                                        setPasscode('');
                                    }, 500);
                                }, 600);
                            }, 1000); 
                        } else {
                            setAltLoginState('error');
                            setTimeout(() => {
                                setAltLoginState('idle');
                                setSliderValue(0); 
                                setPasscode(''); 
                            }, 1500); 
                        }
                    }, 2000); 
                }
            };

            const handleSliderRelease = () => {
                if (altLoginState === 'idle' && sliderValue < 99) {
                    setSliderValue(0); 
                }
            };

            const isOverload = activeUsers > 20000; 

            const applyMode = (users, c, r) => {
                setBaseCount(users);
                setBaseCpu(c);
                setBaseRam(r);
            };

            return (
                <div className="w-full relative z-10">
                    {view === 'login' && (
                        <div className={`glass-panel text-center items-center sm:p-12 p-8 ${isExiting ? 'slide-out-left' : 'animate-slide-down'}`}>
                            
                            {/* ALİCİMMMM BALIMMM LOGON BURADA - logolast.png */}
                            <div className="flex justify-center w-full mb-2">
                                <img src="logolast.png" alt="logo" className="hlogo-last-style pointer-events-none" onError={(e) => e.target.style.display = 'none'} />
                            </div>

                            {/* PARIL PARIL YANAN GİRİŞ BAŞLIĞIMIZ BALIM */}
                            <h1 className="animated-title login-title-effect text-4xl mb-8">hizliyim.com</h1>
                            
                            {loginError && (
                                <div className="w-full bg-red-500/20 border border-red-500/50 text-red-200 p-3 rounded-xl mb-4 text-sm font-bold animate-pulse">
                                    {loginError}
                                </div>
                            )}

                            <form onSubmit={handleLogin} className="w-full space-y-4">
                                <input 
                                    type="text" placeholder="Yönetici Kimliği" 
                                    className="custom-input" required
                                    value={user.email} 
                                    onChange={e => { setUser({...user, email: e.target.value}); setLoginError(''); }}
                                    autoCapitalize="none"
                                    autoCorrect="off"
                                    spellCheck="false"
                                />
                                <input 
                                    type="password" placeholder="Güvenlik Şifresi" 
                                    className="custom-input" required
                                    value={user.pass} 
                                    onChange={e => { setUser({...user, pass: e.target.value}); setLoginError(''); }}
                                />
                                <button type="submit" className="action-btn">
                                    {loading ? "Giriş Yapılıyor..." : "Giriş Yap"}
                                </button>
                            </form>
                            
                            <div className="w-full mt-6 pt-6 border-t border-white/10">
                                <button 
                                    onClick={() => { setIsExiting(true); setTimeout(() => { setView('alt-login'); setIsExiting(false); }, 600); }}
                                    className="text-[10px] font-bold text-white/50 hover:text-[#027AFF] uppercase tracking-widest transition-colors flex items-center justify-center gap-2 mx-auto"
                                >
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                                    Alternatif Yöntemler
                                </button>
                            </div>
                        </div>
                    )}
                    
                    {view === 'alt-login' && (
                        <div className={`glass-panel text-center items-center sm:p-12 p-8 ${isExiting ? 'slide-out-left' : 'slide-in-right'}`}>
                            <button 
                                onClick={() => { setIsExiting(true); setTimeout(() => { setView('login'); setIsExiting(false); }, 600); }}
                                className="absolute top-6 left-6 text-white/50 hover:text-[#027AFF] transition-colors"
                            >
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
                            </button>
                            
                            <div className="w-16 h-16 bg-[#027AFF]/10 border border-[#027AFF]/30 rounded-full flex items-center justify-center mx-auto mb-6 text-[#027AFF]">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                            </div>
                            
                            <h2 className="text-xl font-black italic mb-3">Cihaz Kimliği İle Giriş</h2>
                            <p className="text-[10px] font-medium text-white/50 leading-relaxed mb-6 px-4">
                                Sistem doğrulama protokolü gereği, bu işlem cihazınızın <span className="text-red-400">donanım kimliğine ve depolama birimine</span> şifreli erişim sağlayacaktır. Verileriniz passcode ile şifrelenmiştir.                            </p>

                            <div className="mb-10 w-full max-w-[200px] mx-auto relative">
                                <p className="text-[9px] font-bold uppercase tracking-widest text-white/40 mb-4 text-center">Passcode</p>
                                
                                <div className="flex justify-center gap-4 relative z-10">
                                    <input 
                                        ref={passcodeRef}
                                        type="tel" 
                                        inputMode="numeric"
                                        maxLength="4" 
                                        className="absolute inset-0 w-full h-full opacity-0 z-20 cursor-text"
                                        value={passcode}
                                        onChange={handlePasscodeChange}
                                        disabled={altLoginState !== 'idle'}
                                    />
                                    {[0, 1, 2, 3].map((index) => (
                                        <div key={index} className="w-5 h-5 rounded-full bg-black/40 border border-white/20 flex items-center justify-center transition-all duration-300">
                                            {passcode.length > index && (
                                                <div className="w-2.5 h-2.5 bg-white rounded-full animate-star-pop"></div>
                                            )}
                                        </div>
                                    ))}
                                </div>
                            </div>

                            <div className="relative w-full h-14 bg-black/40 rounded-full border border-white/10 overflow-hidden flex items-center shadow-inner">
                                {altLoginState === 'idle' && (
                                    <>
                                        <span className="absolute w-full text-center text-[10px] font-black slide-text-gradient pointer-events-none tracking-widest pl-8">
                                            GİRİŞ İÇİN KAYDIRIN &gt;&gt;
                                        </span>
                                        
                                        <div className="absolute left-0 top-0 h-full bg-gradient-to-r from-[#027AFF]/40 via-[#027AFF]/70 to-[#00f3ff] backdrop-blur-md shadow-[-20px_0_25px_rgba(0,243,255,0.8)] rounded-full z-0" 
                                             style={{ 
                                                 width: `calc(56px + ${sliderValue}% - ${sliderValue * 0.56}px)`, 
                                                 transition: sliderValue === 0 ? 'width 0.5s cubic-bezier(0.16, 1, 0.3, 1)' : 'none' 
                                             }}></div>
                                        
                                        <input 
                                            type="range" min="0" max="100" 
                                            value={sliderValue} 
                                            onChange={handleSliderChange}
                                            onMouseUp={handleSliderRelease}
                                            onTouchEnd={handleSliderRelease}
                                            className="swipe-hidden-input"
                                        />
                                        
                                        <div className="absolute h-[48px] w-[48px] bg-white rounded-full flex items-center justify-center shadow-lg pointer-events-none z-10"
                                             style={{ 
                                                 left: `calc(4px + ${sliderValue}% - ${sliderValue * 0.56}px)`, 
                                                 top: '4px',
                                                 transition: sliderValue === 0 ? 'left 0.5s cubic-bezier(0.16, 1, 0.3, 1)' : 'none'
                                             }}>
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#027AFF" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                                        </div>
                                    </>
                                )}
                                
                                {altLoginState === 'loading' && (
                                    <div className="w-full flex items-center justify-center gap-3 animate-pop-in">
                                        <div className="w-5 h-5 border-2 border-[#027AFF]/20 border-t-[#027AFF] rounded-full animate-spin"></div>
                                        <span className="text-[10px] font-bold uppercase tracking-widest text-[#027AFF]">Kimlik Doğrulanıyor...</span>
                                    </div>
                                )}
                                
                                {altLoginState === 'success' && (
                                    <div className="w-full flex items-center justify-center gap-2 animate-pop-in text-green-400">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                        <span className="text-[10px] font-black uppercase tracking-widest">Onaylandı: root</span>
                                    </div>
                                )}

                                {altLoginState === 'error' && (
                                    <div className="w-full flex items-center justify-center gap-2 animate-pop-in text-red-500">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                        <span className="text-[10px] font-black uppercase tracking-widest">BAŞARISIZ GİRİŞ!</span>
                                    </div>
                                )}
                            </div>
                        </div>
                    )}

                    {view === 'dashboard' && (
                        <div className={`glass-panel slide-in-right sm:p-10 p-6 ${isOverload ? 'overload-panel' : ''} transition-all duration-700 w-full`}>
                            
                            <div className="scan-bar-container">
                                <div className={`scan-bar-indicator backdrop-blur-md ${isOverload ? 'bg-red-500/80 shadow-[0_0_15px_rgba(239,68,68,0.8)]' : 'bg-[#027AFF]/80 shadow-[0_0_15px_rgba(2,122,255,0.8)]'}`}></div>
                            </div>

                            {!showSettings ? (
                                <div>
                                    <div className="flex items-center justify-between mb-8 pb-4 border-b border-white/10 relative mt-2 gap-2">
                                        {/* ANA MENÜDEKİ ASİL PARLAMALI BAŞLIĞIMIZ BALIM */}
                                        <h1 className="animated-title dashboard-title-effect text-xl sm:text-2xl mb-0" style={{marginBottom: 0}}>hizliyim.com</h1>
                                        
                                        <div className="flex items-center gap-2 sm:gap-3 shrink-0">
                                            <button className="relative bg-black/30 border border-white/20 p-2 rounded-xl hover:bg-black/50 transition-all text-white/80">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                                                <span className="absolute -top-1 -right-1 w-2.5 h-2.5 bg-[#027AFF] rounded-full animate-pulse shadow-[0_0_8px_#027AFF] border border-black"></span>
                                            </button>

                                            <div className="relative">
                                                <button 
                                                    onClick={() => setShowAccountMenu(!showAccountMenu)}
                                                    className="flex items-center gap-2 bg-black/30 border border-white/20 p-2 rounded-xl hover:bg-black/50 transition-all text-white/80"
                                                >
                                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                                </button>

                                                {showAccountMenu && (
                                                    <div className="absolute top-full right-0 mt-2 w-48 bg-black/80 backdrop-blur-xl border border-white/20 rounded-2xl shadow-2xl p-2 z-50">
                                                        <div className="px-3 py-2 border-b border-white/10 mb-1">
                                                            <p className="text-[10px] text-blue-400 font-bold uppercase tracking-widest">Yetki: ROOT</p>
                                                            <p className="text-sm font-bold">@{user.email}</p>
                                                        </div>
                                                        <button 
                                                            onClick={() => { setShowSettings(true); setShowAccountMenu(false); }}
                                                            className="w-full text-left px-3 py-2 text-sm font-bold hover:bg-white/10 rounded-xl transition-all flex items-center justify-between"
                                                        >
                                                            Sistem Kontrolü
                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                                                        </button>
                                                        <button 
                                                            onClick={() => { setView('login'); setShowAccountMenu(false); }}
                                                            className="w-full text-left px-3 py-2 text-sm font-bold hover:bg-red-500/20 text-red-400 rounded-xl transition-all flex items-center justify-between"
                                                        >
                                                            Güvenli Çıkış
                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                                        </button>
                                                    </div>
                                                )}
                                            </div>
                                        </div>
                                    </div>

                                    <div className="text-center mb-8">
                                        {isOverload && (
                                            <div className="flex items-center justify-center gap-2 mb-3 text-red-500 animate-pulse">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                                <span className="font-black text-sm tracking-widest">SİSTEM OVERLOAD</span>
                                            </div>
                                        )}
                                        <p className="text-xs font-bold uppercase tracking-[0.3em] opacity-50 mb-2">Canlı Aktif Kullanıcı</p>
                                        
                                        <div className="relative inline-block">
                                            <span 
                                                className={`text-6xl sm:text-7xl font-black italic tracking-tighter ${isOverload ? 'text-red-500 static-overload-glow' : 'text-white static-glow'}`}
                                            >
                                                <AnimatedNumber value={activeUsers} />
                                            </span>
                                        </div>
                                        
                                        <div className="w-full h-2 bg-black/40 rounded-full mt-6 overflow-hidden border border-white/10">
                                            {/* BARIN DOLULUK ORANI 40K'YA GÖRE HESAPLANIR BALIM */}
                                            <div 
                                                className={`h-full transition-all duration-1000 ${isOverload ? 'bg-red-500' : 'bg-[#027AFF]'}`} 
                                                style={{ width: `${Math.min((activeUsers / 40000) * 100, 100)}%` }}
                                            ></div>
                                        </div>
                                    </div>

                                    <div className="space-y-4">
                                        <div className="bg-black/30 border border-white/10 rounded-2xl p-4 flex gap-3">
                                            <div className="mt-1 text-[#027AFF]">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                            </div>
                                            <div>
                                                <p className="text-[10px] font-bold uppercase tracking-widest text-[#027AFF] mb-1">Genel Duyuru</p>
                                                <p className="text-sm font-medium opacity-90 italic">"{announcement}"</p>
                                            </div>
                                        </div>

                                        <div className="grid grid-cols-2 gap-4">
                                            <div className="bg-black/20 border border-white/10 rounded-xl p-4">
                                                <p className="text-[10px] font-bold uppercase tracking-widest opacity-50 mb-1">CPU Yükü</p>
                                                <p className="text-xl font-black italic text-white/90">
                                                    %<span className="static-glow"><AnimatedNumber value={cpu} decimals={1} /></span>
                                                </p>
                                            </div>
                                            <div className="bg-black/20 border border-white/10 rounded-xl p-4">
                                                <p className="text-[10px] font-bold uppercase tracking-widest opacity-50 mb-1">RAM Bellek</p>
                                                <p className="text-xl font-black italic text-white/90">
                                                    %<span className="static-glow"><AnimatedNumber value={ram} decimals={1} /></span>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            ) : (
                                <div className="animate-pop-in mt-2 sm:mt-4">
                                    <div className="flex items-center justify-between mb-6 sm:mb-8 border-b border-white/10 pb-4 gap-2">
                                        <button 
                                            onClick={() => setShowSettings(false)} 
                                            className="flex items-center gap-1 sm:gap-2 text-xs sm:text-sm font-bold opacity-80 hover:opacity-100 hover:text-[#027AFF] transition-all bg-black/30 px-3 py-2 rounded-xl border border-white/10 shrink-0"
                                        >
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
                                            <span className="hidden sm:inline">Geri Dön</span>
                                            <span className="sm:hidden">Geri</span>
                                        </button>
                                        <h3 className="font-black italic uppercase text-blue-400 text-xs sm:text-sm text-right">Sistem Kontrolü</h3>
                                    </div>
                                    
                                    <div className="space-y-6">
                                        <div className="bg-black/30 p-4 rounded-2xl border border-white/10">
                                            <h4 className="text-[10px] font-bold opacity-50 uppercase tracking-widest mb-3 text-center">Hızlı Sistem Modları</h4>
                                            
                                            {/* YENİ 5 MODLU KUSURSUZ DİZİLİM BALIM */}
                                            <div className="grid grid-cols-2 sm:grid-cols-5 gap-2 sm:gap-3">
                                                <button onClick={() => applyMode(4000, 20, 25)} className="flex flex-col items-center justify-center bg-white/5 hover:bg-[#027AFF]/20 border border-white/10 hover:border-[#027AFF]/50 p-2 sm:p-3 rounded-xl transition-all w-full h-full">
                                                    <span className="text-[10px] sm:text-xs font-bold">MOD 1</span>
                                                    <span className="opacity-50 font-normal mt-0.5 text-[8px] sm:text longevity-10px]">Yoğun</span>
                                                </button>
                                                <button onClick={() => applyMode(10500, 68, 75)} className="flex flex-col items-center justify-center bg-white/5 hover:bg-[#027AFF]/20 border border-white/10 hover:border-[#027AFF]/50 p-2 sm:p-3 rounded-xl transition-all w-full h-full">
                                                    <span className="text-[10px] sm:text-xs font-bold">MOD 2</span>
                                                    <span className="opacity-50 font-normal mt-0.5 text-[8px] sm:text-[10px]">Yoğun</span>
                                                </button>
                                                <button onClick={() => applyMode(16000, 85, 90)} className="flex flex-col items-center justify-center bg-white/5 hover:bg-red-500/20 border border-white/10 hover:border-red-500/50 p-2 sm:p-3 rounded-xl transition-all w-full h-full">
                                                    <span className="text-[10px] sm:text-xs font-bold">MOD 3</span>
                                                    <span className="opacity-50 font-normal text-red-300 mt-0.5 text-[8px] sm:text-[10px]">Overload</span>
                                                </button>
                                                {/* İSTEDİĞİN 2 YENİ FELAKET MODU BALIM */}
                                                <button onClick={() => applyMode(20000, 95, 90)} className="flex flex-col items-center justify-center bg-white/5 hover:bg-red-600/30 border border-white/10 hover:border-red-600/50 p-2 sm:p-3 rounded-xl transition-all w-full h-full">
                                                    <span className="text-[10px] sm:text-xs font-bold">MOD 4</span>
                                                    <span className="opacity-50 font-normal text-red-400 mt-0.5 text-[8px] sm:text-[10px]">Kritik</span>
                                                </button>
                                                <button onClick={() => applyMode(27000, 98, 95)} className="flex flex-col items-center justify-center bg-white/5 hover:bg-red-700/40 border border-white/10 hover:border-red-700/60 p-2 sm:p-3 rounded-xl transition-all w-full h-full sm:col-span-1 col-span-2">
                                                    <span className="text-[10px] sm:text-xs font-bold">MOD 5</span>
                                                    <span className="opacity-50 font-normal text-red-500 mt-0.5 text-[8px] sm:text-[10px]">Felaket</span>
                                                </button>
                                            </div>
                                        </div>

                                        <div className="bg-black/30 p-5 rounded-2xl border border-white/10">
                                            <div className="flex justify-between text-xs font-bold opacity-70 mb-4">
                                                <span>Trafik Manipülasyonu</span>
                                                <span className="text-[#027AFF] text-lg">{baseCount.toLocaleString()}</span>
                                            </div>
                                            {/* SLİDER MAX SINIRI 40.000 YAPILDI BALIM */}
                                            <input 
                                                type="range" min="100" max="40000" 
                                                value={baseCount} onChange={e => setBaseCount(Number(e.target.value))}
                                                className="w-full mb-4"
                                            />
                                            
                                            <div className="space-y-4 border-t border-white/10 pt-4">
                                                <div>
                                                    <div className="flex justify-between text-[10px] font-bold opacity-70 mb-2 uppercase tracking-widest">
                                                        <span>CPU Yükü</span>
                                                        <span className="text-[#027AFF]">%{baseCpu}</span>
                                                    </div>
                                                    <input 
                                                        type="range" min="1" max="99" 
                                                        value={baseCpu} onChange={e => setBaseCpu(Number(e.target.value))}
                                                        className="w-full"
                                                    />
                                                </div>
                                                <div>
                                                    <div className="flex justify-between text-[10px] font-bold opacity-70 mb-2 uppercase tracking-widest">
                                                        <span>RAM Bellek</span>
                                                        <span className="text-[#027AFF]">%{baseRam}</span>
                                                    </div>
                                                    <input 
                                                        type="range" min="1" max="99" 
                                                        value={baseRam} onChange={e => setBaseRam(Number(e.target.value))}
                                                        className="w-full"
                                                    />
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div className="bg-black/30 p-5 rounded-2xl border border-white/10">
                                            <label className="text-xs font-bold opacity-70 block mb-3 uppercase tracking-widest">Canlı Duyuru Metni Güncelle</label>
                                            <textarea 
                                                className="custom-input h-24 resize-none text-sm"
                                                value={announcement} onChange={e => setAnnouncement(e.target.value)}
                                            />
                                            <p className="text-[10px] opacity-40 mt-2">*Bu metin ana ekranda anında yayınlanır.</p>
                                        </div>
                                    </div>
                                </div>
                            )}

                        </div>
                    )}

                    <div className="mt-8 w-full flex justify-center animate-pop-in opacity-80 hover:opacity-100 transition-opacity">
                        <div className="px-5 py-2.5 rounded-2xl bg-white/5 backdrop-blur-xl border border-white/10 shadow-lg flex items-center">
                            <span className="text-[11px] font-medium tracking-widest text-white/50 lowercase">
                                hizliyim systems - core v4.9
                            </span>
                        </div>
                    </div>

                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>

